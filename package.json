{
  "name": "discovery-x",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remix vite:dev",
    "build": "remix vite:build",
    "start": "wrangler pages dev ./build/client",
    "deploy": "pnpm run build && wrangler pages deploy ./build/client",
    "lint": "eslint app/",
    "typecheck": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply discovery-x-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply discovery-x-db --remote",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@remix-run/cloudflare": "^2.17.4",
    "@remix-run/cloudflare-pages": "^2.17.4",
    "@remix-run/react": "^2.17.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.36.4",
    "isbot": "^4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.1",
    "tiny-invariant": "^1.3.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250519.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.1",
    "@remix-run/dev": "^2.17.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.30.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.0.11",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18",
    "wrangler": "^4.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
