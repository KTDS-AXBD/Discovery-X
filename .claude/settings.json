{
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(pnpm run *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(wrangler *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm typecheck 2>&1 | tail -20; pnpm lint 2>&1 | tail -20"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '\\.dev\\.vars|\\.env|pnpm-lock\\.yaml'; then echo 'BLOCKED: 보호 파일(.dev.vars/.env/pnpm-lock.yaml) 편집이 차단되었습니다. lock 파일은 pnpm install을 사용하세요'; exit 2; fi"
          }
        ]
      }
    ]
  }
}
