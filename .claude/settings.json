{
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(pnpm run *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(wrangler *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm typecheck 2>&1 | tail -20; pnpm lint 2>&1 | tail -20"
          }
        ]
      }
    ]
  }
}
